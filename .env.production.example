# Copy this file to .env on your VPS and fill in real values
# Location: /var/www/thespaceos/.env

# ── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://spaceuser:YOUR_DB_PASSWORD@localhost:5432/thespaceos

# ── API Server ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Auth / Sessions ─────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 32
SESSION_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# ── Frontend build vars (used at build time only, not at runtime) ────────────
# Keep BASE_PATH as "/" for root-domain deployments
BASE_PATH=/

# ── Optional: add any other secrets your app uses ───────────────────────────
# e.g. email service keys, SMS keys, etc.
